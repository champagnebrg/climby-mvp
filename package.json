{
  "name": "climby-rules-tests",
  "private": true,
  "scripts": {
    "test:rules": "firebase emulators:exec --project climby-rules-test --only firestore \"node --test tests/firestore-competition-live.rules.test.js tests/firestore-challenges.rules.test.js\"",
    "deploy:indexes": "npm run deploy:indexes:dev",
    "deploy:firestore": "npm run deploy:firestore:dev",
    "deploy:indexes:dev": "firebase deploy --project climby-dev-1 --only firestore:indexes",
    "deploy:firestore:dev": "firebase deploy --project climby-dev-1 --only firestore:rules,firestore:indexes",
    "deploy:indexes:prod": "firebase deploy --project climby-mvp-c61d7 --only firestore:indexes",
    "deploy:firestore:prod": "firebase deploy --project climby-mvp-c61d7 --only firestore:rules,firestore:indexes"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "firebase": "^12.0.0",
    "firebase-tools": "^14.0.0"
  }
}
